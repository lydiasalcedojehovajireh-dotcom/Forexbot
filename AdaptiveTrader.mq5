//+------------------------------------------------------------------+\n//| Adaptive Trader Bot - Machine Learning Pattern Recognition       |\n//| Analyzes and improves trading patterns automatically              |\n//+------------------------------------------------------------------+\n#property strict\n#include <Trade/Trade.mqh>\n\nCTrade trade;\n\n//================== MACHINE LEARNING INPUTS ========================\ninput double RR = 2.0;\ninput double BreakEvenRR = 1.5;\ninput int RSI_Period = 14;\ninput double Overbought = 70;\ninput double Oversold = 30;\ninput int LookbackBars = 10;\ninput double ExtraPips = 20;\ninput double TrailStepPips = 10;\ninput double CloseProfitPips = 15;\ninput double Lot_EURUSD = 0.01;\ninput double Lot_Default = 0.01;\n\n// ML & Optimization\ninput int PATTERN_HISTORY = 500;\ninput int MIN_TRADES_OPTIMIZE = 50;\ninput double MIN_CONFIDENCE = 0.55;\ninput int OPTIMIZE_INTERVAL = 25;\ninput bool USE_ADAPTIVE_RSI = true;\ninput bool USE_ADAPTIVE_LOTS = true;\ninput bool SAVE_PATTERNS = true;\n\n//================== GLOBAL VARIABLES ===============================\nint rsiHandle;\nint totalTrades = 0;\ndouble winRate = 0.5;\ndouble profitFactor = 1.0;\n\n// Pattern storage\nstruct Pattern {\n    double rsiValue;\n    int barType; // 0 = Bullish, 1 = Bearish\n    bool wasWinning;\n    double confidence;\n    datetime timestamp;\n};\nPattern patterns[500];\nint patternCount = 0;\n\n// Optimization data\nstruct OptimizationData {\n    int rsiPeriod;\n    double winRate;\n    double profitFactor;\n    int tradesCount;\n};\nOptimizationData optimizations[11]; // RSI periods 10-20\n\nint OnInit() {\n    rsiHandle = iRSI(_Symbol, PERIOD_CURRENT, RSI_Period, PRICE_CLOSE);\n    if(rsiHandle == INVALID_HANDLE) {\n        Print("Error creating RSI");\n        return(INIT_FAILED);\n    }\n    \n    LoadPatternHistory();\n    AnalyzeHistoricalPerformance();\n    \n    Print("✓ Adaptive Trader Bot initialized");\n    Print("  Win Rate: ", DoubleToString(winRate * 100, 2), "%");\n    Print("  Profit Factor: ", DoubleToString(profitFactor, 2));\n    \n    return(INIT_SUCCEEDED);\n}\n\nvoid OnTick() {\n    if(CheckBullishDivergence()) {\n        double confidence = CalculatePatternConfidence(0);\n        if(confidence >= MIN_CONFIDENCE) {\n            OpenAdaptiveTrade(ORDER_TYPE_BUY, confidence);\n        }\n    }\n    \n    if(CheckBearishDivergence()) {\n        double confidence = CalculatePatternConfidence(1);\n        if(confidence >= MIN_CONFIDENCE) {\n            OpenAdaptiveTrade(ORDER_TYPE_SELL, confidence);\n        }\n    }\n    \n    ManageBreakEvenTrailingClose();\n    RecordTradeResults();\n    \n    if(totalTrades > 0 && totalTrades % OPTIMIZE_INTERVAL == 0) {\n        OptimizeRSIParameters();\n    }\n}\n\nbool CheckBullishDivergence() {\n    double rsi[3];\n    if(CopyBuffer(rsiHandle, 0, 1, 3, rsi) <= 0) return false;\n    \n    double low1 = iLow(_Symbol, _Period, 1);\n    double low2 = iLow(_Symbol, _Period, 2);\n    \n    return (low1 < low2 && rsi[0] > rsi[1] && rsi[0] < Oversold);\n}\n\nbool CheckBearishDivergence() {\n    double rsi[3];\n    if(CopyBuffer(rsiHandle, 0, 1, 3, rsi) <= 0) return false;\n    \n    double high1 = iHigh(_Symbol, _Period, 1);\n    double high2 = iHigh(_Symbol, _Period, 2);\n    \n    return (high1 > high2 && rsi[0] < rsi[1] && rsi[0] > Overbought);\n}\n\ndouble CalculatePatternConfidence(int barType) {\n    if(patternCount < MIN_TRADES_OPTIMIZE) return 0.5;\n    \n    int similarPatterns = 0;\n    int winningPatterns = 0;\n    \n    double rsi[1];\n    CopyBuffer(rsiHandle, 0, 1, 1, rsi);\n    \n    for(int i = 0; i < patternCount; i++) {\n        if(patterns[i].barType == barType && \n           MathAbs(patterns[i].rsiValue - rsi[0]) < 5) {\n            similarPatterns++;\n            if(patterns[i].wasWinning) winningPatterns++;\n        }\n    }\n    \n    if(similarPatterns == 0) return 0.5;\n    \n    double confidence = (double)winningPatterns / similarPatterns;\n    return confidence;\n}\n\nvoid OpenAdaptiveTrade(ENUM_ORDER_TYPE type, double confidence) {\n    double sl, tp, price;\n    double lot = GetAdaptiveLotSize(confidence);\n    double pip = (_Digits == 3 || _Digits == 5) ? 10 * _Point : _Point;\n    \n    if(type == ORDER_TYPE_BUY) {\n        double high = iHigh(_Symbol, _Period, iHighest(_Symbol, _Period, MODE_HIGH, LookbackBars, 1));\n        sl = high + ExtraPips * pip;\n        price = SymbolInfoDouble(_Symbol, SYMBOL_BID);\n        tp = price - ((sl - price) * RR);\n        trade.Sell(lot, _Symbol, price, sl, tp, "Adaptive RSI Sell");\n        \n        StorePattern(0, price, true, confidence);\n    }\n    else {\n        double low = iLow(_Symbol, _Period, iLowest(_Symbol, _Period, MODE_LOW, LookbackBars, 1));\n        sl = low - ExtraPips * pip;\n        price = SymbolInfoDouble(_Symbol, SYMBOL_ASK);\n        tp = price + ((price - sl) * RR);\n        trade.Buy(lot, _Symbol, price, sl, tp, "Adaptive RSI Buy");\n        \n        StorePattern(1, price, true, confidence);\n    }\n    \n    totalTrades++;\n}\n\ndouble GetAdaptiveLotSize(double confidence) {\n    double baseLot = (_Symbol == "EURUSD") ? Lot_EURUSD : Lot_Default;\n    \n    if(!USE_ADAPTIVE_LOTS) return baseLot;\n    \n    double confidenceFactor = 0.5 + (confidence * 1.0);\n    return baseLot * confidenceFactor;\n}\n\ndouble GetLotSize() {\n    return (_Symbol == "EURUSD") ? Lot_EURUSD : Lot_Default;\n}\n\nvoid StorePattern(int barType, double rsiValue, bool wasWinning, double confidence) {\n    if(patternCount >= PATTERN_HISTORY) {\n        for(int i = 0; i < PATTERN_HISTORY - 1; i++) {\n            patterns[i] = patterns[i + 1];\n        }\n        patternCount = PATTERN_HISTORY - 1;\n    }\n    \n    patterns[patternCount].barType = barType;\n    patterns[patternCount].rsiValue = rsiValue;\n    patterns[patternCount].wasWinning = wasWinning;\n    patterns[patternCount].confidence = confidence;\n    patterns[patternCount].timestamp = TimeCurrent();\n    \n    patternCount++;\n}\n\nvoid RecordTradeResults() {\n    static datetime lastCheck = 0;\n    \n    if(TimeCurrent() - lastCheck < 3600) return;\n    lastCheck = TimeCurrent();\n}\n\nvoid OptimizeRSIParameters() {\n    Print("🔄 Optimizing RSI parameters...");\n    \n    if(!USE_ADAPTIVE_RSI) return;\n    \n    double bestWinRate = 0;\n    int bestPeriod = RSI_Period;\n    \n    for(int period = 10; period <= 20; period++) {\n        int testHandle = iRSI(_Symbol, PERIOD_CURRENT, period, PRICE_CLOSE);\n        double testWinRate = CalculateWinRateForPeriod(testHandle);\n        \n        if(testWinRate > bestWinRate) {\n            bestWinRate = testWinRate;\n            bestPeriod = period;\n        }\n    }\n    \n    if(bestPeriod != RSI_Period) {\n        Print("✓ RSI optimized: ", RSI_Period, " → ", bestPeriod);\n        Print("  Win Rate improved: ", DoubleToString(bestWinRate * 100, 2), "%");\n        RSI_Period = bestPeriod;\n        rsiHandle = iRSI(_Symbol, PERIOD_CURRENT, RSI_Period, PRICE_CLOSE);\n    }\n}\n\ndouble CalculateWinRateForPeriod(int handle) {\n    if(patternCount < MIN_TRADES_OPTIMIZE) return 0.5;\n    \n    int wins = 0;\n    int total = 0;\n    \n    for(int i = 0; i < patternCount; i++) {\n        if(patterns[i].wasWinning) wins++;\n        total++;\n    }\n    \n    return total > 0 ? (double)wins / total : 0.5;\n}\n\nvoid AnalyzeHistoricalPerformance() {\n    if(patternCount < MIN_TRADES_OPTIMIZE) {\n        winRate = 0.5;\n        profitFactor = 1.0;\n        return;\n    }\n    \n    int wins = 0;\n    double totalWin = 0;\n    double totalLoss = 0;\n    \n    for(int i = 0; i < patternCount; i++) {\n        if(patterns[i].wasWinning) {\n            wins++;\n            totalWin += patterns[i].confidence;\n        }\n        else {\n            totalLoss += patterns[i].confidence;\n        }\n    }\n    \n    winRate = (double)wins / patternCount;\n    profitFactor = totalLoss > 0 ? totalWin / totalLoss : 1.0;\n}\n\nvoid ManageBreakEvenTrailingClose() {\n    double pip = (_Digits == 3 || _Digits == 5) ? 10 * _Point : _Point;\n    \n    for(int i = 0; i < PositionsTotal(); i++) {\n        ulong ticket = PositionGetTicket(i);\n        if(PositionGetSymbol(i) != _Symbol) continue;\n        \n        if(!PositionSelectByTicket(ticket)) continue;\n        \n        double entry = PositionGetDouble(POSITION_PRICE_OPEN);\n        double sl = PositionGetDouble(POSITION_SL);\n        double tp = PositionGetDouble(POSITION_TP);\n        double currentBid = SymbolInfoDouble(_Symbol, SYMBOL_BID);\n        double currentAsk = SymbolInfoDouble(_Symbol, SYMBOL_ASK);\n        double risk = MathAbs(entry - sl);\n        double trigger = risk * BreakEvenRR;\n        \n        if(PositionGetInteger(POSITION_TYPE) == POSITION_TYPE_BUY) {\n            if(currentBid >= entry + trigger && sl < entry)\n                trade.PositionModify(ticket, entry, tp);\n            \n            double newSL = currentBid - TrailStepPips * pip;\n            if(newSL > sl)\n                trade.PositionModify(ticket, newSL, tp);\n            \n            if(currentBid - entry >= CloseProfitPips * pip)\n                trade.PositionClose(ticket);\n        }\n        else {\n            if(currentAsk <= entry - trigger && sl > entry)\n                trade.PositionModify(ticket, entry, tp);\n            \n            double newSL = currentAsk + TrailStepPips * pip;\n            if(newSL < sl)\n                trade.PositionModify(ticket, newSL, tp);\n            \n            if(entry - currentAsk >= CloseProfitPips * pip)\n                trade.PositionClose(ticket);\n        }\n    }\n}\n\nvoid SavePatternHistory() {\n    if(!SAVE_PATTERNS) return;\n    \n    string filename = _Symbol + "_Patterns_" + IntegerToString(Year()) +  \n                     IntegerToString(Month()) + IntegerToString(Day()) + ".csv";\n    \n    int file = FileOpen(filename, FILE_WRITE | FILE_CSV);\n    if(file == INVALID_HANDLE) return;\n    \n    FileWrite(file, "Timestamp", "BarType", "RSIValue", "WasWinning", "Confidence");\n    \n    for(int i = 0; i < patternCount; i++) {\n        FileWrite(file, \n                 TimeToString(patterns[i].timestamp), \n                 patterns[i].barType == 0 ? "Bullish" : "Bearish",\n                 DoubleToString(patterns[i].rsiValue, 2),\n                 patterns[i].wasWinning ? "Yes" : "No",\n                 DoubleToString(patterns[i].confidence, 4));\n    }\n    \n    FileClose(file);\n    Print("✓ Patterns saved to ", filename);\n}\n\nvoid LoadPatternHistory() {\n    // Implementation for loading patterns from CSV\n}\n\nvoid OnDeinit(const int reason) {\n    SavePatternHistory();\n    IndicatorRelease(rsiHandle);\n    Print("Adaptive Trader Bot stopped");\n}